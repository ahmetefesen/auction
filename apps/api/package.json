{
  "name": "@auction/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=../../.env dist/index.js",
    "lint": "eslint . && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run src/integration",
    "worker": "tsx --env-file=../../.env src/worker.ts"
  },
  "dependencies": {
    "@auction/db": "workspace:*",
    "@auction/shared": "workspace:*",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.0",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/static": "^8.0.3",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.5",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "nodemailer": "^6.9.16",
    "pino": "^9.6.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@auction/config": "workspace:*",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^3.2.4"
  }
}
