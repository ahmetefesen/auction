{
  "name": "auction",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @auction/db generate",
    "db:migrate": "pnpm --filter @auction/db migrate:dev",
    "db:seed": "pnpm --filter @auction/db seed",
    "db:deploy": "pnpm --filter @auction/db migrate:deploy",
    "test": "pnpm --filter @auction/api test",
    "test:integration": "pnpm --filter @auction/api test:integration"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
