# PostgreSQL 16 (docker compose)
DATABASE_URL=postgresql://auction:auction@localhost:5432/auction?schema=public

# Redis (docker compose redis, or brew services start redis)
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COOKIE_SECURE=false

# API
API_HOST=0.0.0.0
API_PORT=4000
CORS_ORIGIN=http://localhost:3000
CURRENCY=TRY
UPLOAD_DIR=./uploads

# SMTP (Mailhog from docker compose — UI http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@auction.local

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
